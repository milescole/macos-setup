[user]
    name = First Last
    email = me@example.com

[core]
    autocrlf = input

[init]
    defaultBranch = main

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[fetch]
    prune = true
    pruneTags = true

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[merge]
    conflictstyle = diff3

[diff]
    algorithm = histogram
    mnemonicPrefix = true
    renames = true

[color]
    ui = auto

[column]
    ui = auto

[commit]
    verbose = true

[help]
    autocorrect = prompt

[alias]
    st = status
    ci = commit
    co = checkout
    lg = log --graph --date=relative --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ad)%Creset'
    oops = commit --amend --no-edit
    reword = commit --amend
    uncommit = reset --soft HEAD~1
    untrack = rm --cached --

[rebase]
    autoSquash = true
    autoStash = true

[rerere]
    enabled = true
    autoupdate = true
