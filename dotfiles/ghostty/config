# === Theme and Colors ===
theme = Catppuccin Mocha

# === Appearance ===
background-opacity = 0.85
background-blur = 16

# === Font Configuration ===
font-family = "FiraCode Nerd Font Mono"
font-size = 14

# === Window Layout ===
window-position-x = 0
window-position-y = 0
window-save-state = always

# === Shell Integration ===
shell-integration = "detect"
scrollbar = never
window-padding-x = 5
window-padding-y = 5
macos-titlebar-style = tabs

# === Keybindings ===
keybind = shift+enter=text:\x1b\r
